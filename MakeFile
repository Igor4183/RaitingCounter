CXX = g++-14
CXXFLAGS = -g -std=c++20 -Wall -Wextra -Iinclude -mmacosx-version-min=26.0

SRC = src/main.cpp src/config.cpp src/parser.cpp src/model.cpp src/u32string.cpp src/generator.cpp
OBJ = build/main.o build/config.o build/parser.o build/model.o build/u32string.o build/generator.o

TARGET = app

all: $(TARGET)

$(TARGET): $(OBJ)
	$(CXX) $(CXXFLAGS) -o $(TARGET) $(OBJ)

build/%.o: src/%.cpp
	mkdir -p build
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	rm -rf build $(TARGET)

run: all
	./$(TARGET)